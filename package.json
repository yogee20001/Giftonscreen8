{
  "name": "giftonscreen",
  "version": "1.0.0",
  "description": "Create beautiful digital gifts for your loved ones",
  "scripts": {
    "deploy": "npm run deploy:worker && npm run deploy:pages",
    "deploy:worker": "cd worker && wrangler deploy",
    "deploy:pages": "wrangler pages deploy . --project-name=giftonscreen8",
    "dev:worker": "cd worker && wrangler dev",
    "logs:worker": "cd worker && wrangler tail",
    "secrets:list": "wrangler secret list",
    "secrets:list:worker": "cd worker && wrangler secret list"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "0g": "^0.4.2",
    "opencode-ai": "^1.3.15"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yogee20001/Giftonscreen8.git"
  },
  "keywords": [
    "gifts",
    "digital-gifts",
    "cloudflare",
    "supabase"
  ],
  "license": "MIT"
}
